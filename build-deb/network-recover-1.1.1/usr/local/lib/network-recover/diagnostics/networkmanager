#!/bin/bash
check_networkmanager() {
    if ! command -v nmcli &>/dev/null; then
        echo "  ℹ️  NetworkManager not installed"
        return 0
    fi
    
    if systemctl is-active NetworkManager &>/dev/null; then
        local state=$(nmcli -t -f GENERAL.STATE general status 2>/dev/null | cut -d: -f2)
        echo "  ✅ NetworkManager is running (state: ${state:-unknown})"
        return 0
    else
        echo "  ❌ NetworkManager is NOT running"
        return 1
    fi
}