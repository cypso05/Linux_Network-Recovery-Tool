#!/bin/bash
check_ip() {
    local iface="${1:-${BRIDGE_IFACE:-$DEFAULT_IFACE}}"
    
    local ipv4=$(ip -4 addr show "$iface" 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}/\d+' | head -1)
    
    if [[ -n "$ipv4" ]]; then
        echo "  ✅ IPv4: $ipv4"
        return 0
    else
        echo "  ❌ No IPv4 address on $iface"
        return 1
    fi
}