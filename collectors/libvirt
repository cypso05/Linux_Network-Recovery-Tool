#!/bin/bash
collect_libvirt() {
    if ! command -v virsh &>/dev/null; then
        echo "=== libvirt: not installed ==="
        return 0
    fi
    echo "=== virsh list --all ==="
    virsh list --all 2>/dev/null
    echo ""
    echo "=== virsh net-list --all ==="
    virsh net-list --all 2>/dev/null || echo "  No virtual networks"
    return 0
}