[Desktop Entry]
Version=1.0
Type=Application
Name=Network Recovery Tool
Comment=Diagnose and fix network connectivity issues
Exec=/usr/local/bin/network-recover-gui
Icon=network-recover
Terminal=false
Categories=Network;
StartupNotify=true
Actions=diagnose;repair;status;snapshot;watch;web-ui;cli-gui

[Desktop Action diagnose]
Name=🔍 Diagnose Network
Exec=sh -c "/usr/local/bin/network-recover-gui diagnose"

[Desktop Action repair]
Name=🔧 Repair Network
Exec=sh -c "/usr/local/bin/network-recover-gui repair"

[Desktop Action status]
Name=📊 Network Status
Exec=sh -c "/usr/local/bin/network-recover-gui status"

[Desktop Action snapshot]
Name=💾 Save Snapshot
Exec=sh -c "/usr/local/bin/network-recover-gui snapshot"

[Desktop Action watch]
Name=📡 Monitor Network
Exec=sh -c "/usr/local/bin/network-recover-gui watch"

[Desktop Action web-ui]
Name=🌐 Open Web UI
Exec=sh -c "/usr/local/bin/network-recover-web"

[Desktop Action cli-gui]
Name=🖥️ CLI GUI (Zenity)
Exec=/usr/local/bin/network-recover-gui